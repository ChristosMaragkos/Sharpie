; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SharpieStudio"
run/main_scene="uid://w2cffjowmdw6"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
boot_splash/bg_color=Color(0.24313726, 0.88235295, 0.8117647, 1)
boot_splash/stretch_mode=0
boot_splash/image="uid://b6k1fwaqed2cg"
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2

[dotnet]

project/assembly_name="SharpieStudio"
project/solution_directory="../"

[global_group]

DesktopIcons=""
OpenWindows=""
ActiveWindow=""

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
